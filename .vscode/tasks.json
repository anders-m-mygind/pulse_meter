{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run All Tests",
      "type": "shell",
      "command": "flutter",
      "args": ["test", "-v"],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": ["$flutter-test"],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Run Tests with Coverage",
      "type": "shell",
      "command": "flutter",
      "args": ["test", "--coverage"],
      "group": "test",
      "problemMatcher": ["$flutter-test"],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Run Widget Tests",
      "type": "shell",
      "command": "flutter",
      "args": ["test", "test/widget_test.dart", "test/app_test.dart", "-v"],
      "group": "test",
      "problemMatcher": ["$flutter-test"],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Run Unit Tests",
      "type": "shell",
      "command": "flutter",
      "args": ["test", "test/unit/", "-v"],
      "group": "test",
      "problemMatcher": ["$flutter-test"],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Analyze Code",
      "type": "shell",
      "command": "flutter",
      "args": ["analyze"],
      "group": "test",
      "problemMatcher": ["$flutter-lint"],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Format Code",
      "type": "shell",
      "command": "dart",
      "args": ["format", "lib/", "test/", "-l", "100"],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Run App (Debug)",
      "type": "shell",
      "command": "flutter",
      "args": ["run"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
